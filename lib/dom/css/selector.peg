# CSS selector grammar (Level 3 subset), consumed by Pegasus.
#
# Semantic actions in DOM.CSS turn each rule's match into the selector AST in a
# single pass; see the parser-options keyword list there. This file is the
# single source of truth for the grammar.

selector_list <- ws complex (comma complex)* ws

comma <- ws ',' ws

complex <- compound (combinator compound)*

combinator <- ws '>' ws / ws '+' ws / ws '~' ws / descendant

descendant <- ' ' ws

compound <- simple+

ws <- ' '*

simple <- universal / id / class / attribute / type

universal <- '*'
id        <- '#' name
class      <- '.' name
type      <- name

attribute <- '[' name (attr_op attr_value attr_flag?)? ']'

attr_op <- '~=' / '|=' / '^=' / '$=' / '*=' / '='

attr_value <- attr_string / name

attr_string <- '"' [^"]* '"' / "'" [^']* "'"

attr_flag <- ' ' [is]

name <- [-_a-zA-Z] [-_a-zA-Z0-9]*
